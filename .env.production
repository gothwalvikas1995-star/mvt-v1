# ── App ─────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
ALLOWED_ORIGINS=https://your-frontend.vercel.app,https://bhc.qcin.org
ENABLE_SWAGGER=true

# ── PostgreSQL (use Neon.tech — free serverless PG) ──────────
DATABASE_URL=postgresql://user:password@ep-xxxx.ap-south-1.aws.neon.tech/bhc_production?sslmode=require

# ── Redis (use Upstash.com — free serverless Redis) ──────────
REDIS_URL=rediss://default:password@your-host.upstash.io:6380

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=bhc_qci_mvt_super_secret_key_min_32_chars_2026_prod
JWT_REFRESH_SECRET=bhc_qci_refresh_secret_key_min_32_chars_2026_prod
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=30d

# ── Twilio SMS ───────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890

# ── Email — SendGrid ─────────────────────────────────────────
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USER=apikey
EMAIL_PASS=SG.your_sendgrid_api_key_here
EMAIL_FROM=noreply@bhc.qcin.org

# ── AWS S3 (ap-south-1 Mumbai) ───────────────────────────────
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=bhc-mvt-assets-prod

# ── Firebase FCM (Push Notifications) ───────────────────────
FIREBASE_PROJECT_ID=bharat-health-connect
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@bharat-health-connect.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"
